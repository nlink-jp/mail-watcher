# mail-watcher configuration
# Copy to config.env and edit values.

# ── Input ──
# Directory where eml/msg files are synced (OneDrive/Google Drive)
WATCH_DIR="$HOME/Library/CloudStorage/OneDrive/ML-Export"

# ── Output ──
# Directory for converted JSONL and analysis metadata
OUTPUT_DIR="$HOME/mail-watcher/data"

# ── Polling ──
# Interval in seconds between directory scans
POLL_INTERVAL=60

# ── LLM ──
# Tool for analysis: "gem-cli" (Vertex AI) or "lite-llm" (OpenAI-compatible)
LLM_TOOL="gem-cli"

# gem-cli: model selection (default: gemini-2.5-flash for cost efficiency)
GEM_MODEL="gemini-2.5-flash"

# Summary language (e.g. "ja" for Japanese, "en" for English, "" for auto-detect)
SUMMARY_LANG=""

# lite-llm: endpoint and model (only used if LLM_TOOL=lite-llm)
LITE_LLM_ENDPOINT=""
LITE_LLM_MODEL=""

# ── Slack ──
# Tool for posting: "swrite" (bot) or "scli" (user token)
SLACK_TOOL="swrite"

# Channel to post notifications
SLACK_CHANNEL="#mail-digest"

# swrite profile (only used if SLACK_TOOL=swrite)
SLACK_PROFILE="default"

# scli workspace name (only used if SLACK_TOOL=scli)
SLACK_WORKSPACE=""
